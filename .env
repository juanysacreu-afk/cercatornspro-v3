# Telegram secrets used by Supabase Edge Functions only.
# These are NOT read by Vite — prefix VITE_ is intentionally omitted.
# Set them as Supabase secrets with:
#   npx supabase secrets set TELEGRAM_BOT_TOKEN=<token> TELEGRAM_CHAT_ID=<chat_id>
#
# This file is safe to commit because it contains no real values.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
